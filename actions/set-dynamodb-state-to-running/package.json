    "@monotonix/dynamodb-common": "workspace:*",
    "@monotonix/schema": "workspace:*"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@types/node": "24.10.9",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "rollup": "4.62.2",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
